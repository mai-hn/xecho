# 将此文件复制为服务器上的 .env，并按实际部署修改。

# GitHub Actions 发布的镜像标签。默认分支可使用 "latest"。
IMAGE_TAG=latest

# 将 OWNER 替换为你的 GitHub 用户名或组织名。
IMAGE=ghcr.io/OWNER/xecho

# 宿主机映射到容器 Web 服务的端口。API 只在容器内部可访问。
WEB_PORT=3000

# 可选。通常 API 请求会通过 Next.js 同源 rewrite 转发。
CORS_ALLOW_ORIGINS=http://localhost:3000

# SQLite 数据库保存在 xecho-data Docker volume 中。
DATABASE_URL=sqlite:////data/model_test.db
