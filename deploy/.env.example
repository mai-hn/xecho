# Copy this file to .env next to docker-compose.yml on the server and edit the values.

# Image tag published by GitHub Actions. Use "latest" for the default branch.
IMAGE_TAG=latest

# Replace OWNER with your GitHub user or organization.
IMAGE=ghcr.io/OWNER/xecho

# Host port mapped to the container's web server. The API stays private inside the container.
WEB_PORT=3000

# Optional. API requests normally go through the Next.js same-origin rewrite.
CORS_ALLOW_ORIGINS=http://localhost:3000

# SQLite database stored in the xecho-data Docker volume.
DATABASE_URL=sqlite:////data/model_test.db
